# Free default DB (SQLite)
DB_PATH=database.db
DATABASE_URL=

# Safe + official sources
NDMA_CAP_URL=https://sachet.ndma.gov.in/CapFeed
OGD_DATASET_URL=
OGD_API_KEY=
MOSDAC_ENDPOINT_URL=
MOSDAC_API_TOKEN=

# Runtime
HTTP_TIMEOUT_SECONDS=20
POLL_INTERVAL_SECONDS=600
ENABLE_SCHEDULER=true
RUN_SYNC_ON_STARTUP=true
REQUEST_RETRIES=5
REQUEST_BACKOFF_SECONDS=1.0
SOURCE_STAGGER_SECONDS=2.0
ENABLE_COLLECTOR_SNAPSHOT=true
COLLECTOR_ALERT_JSON=

# Internal API security (keep private)
REQUIRE_API_KEY=true
INTERNAL_API_KEY=change-this-to-a-long-random-key
API_KEY_HEADER=X-Internal-API-Key
ADMIN_API_KEY=change-this-to-a-different-admin-key
ADMIN_API_KEY_HEADER=X-Admin-API-Key

# JWT auth (free)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=30
JWT_MAX_EXPIRES_MINUTES=240
JWT_ISSUER=internal-disaster-api
JWT_AUDIENCE=internal-clients

# Flask server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

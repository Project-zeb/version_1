# Database Configuration
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_secure_password
DB_NAME=Save_India
PRIMARY_DB=mysql

# Security
SECRET_KEY=your-secret-key-change-in-production

# Google OAuth (if using Google login)
GOOGLE_REDIRECT_URI=http://127.0.0.1:8005/auth/callback

# Internal Alerts API Configuration
INTERNAL_ALERTS_API_URL=http://127.0.0.1:5100/api/alerts
INTERNAL_ALERTS_API_KEY=your-internal-api-key-here
INTERNAL_ALERTS_API_KEY_HEADER=X-Internal-API-Key

# Alert Source Policy
MOBILE_ALERTS_SOURCE_POLICY=live_only

# Optional: SQLite path (for development)
SQLITE_DB_PATH=app.db

# Optional: Additional API Keys for External Services
# OGD_API_KEY=your-data-gov-in-api-key
# MOSDAC_API_TOKEN=your-mosdac-api-token

# Optional: GCP Configuration (if using Google Cloud)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_SERVICE_ACCOUNT_FILE=path/to/service-account.json
